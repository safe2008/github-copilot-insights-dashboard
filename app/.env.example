# Copilot Insights — Environment Variables
# Copy this file to .env and fill in the values

# PostgreSQL connection string
DATABASE_URL=postgresql://user:password@localhost:5432/copilot_insights

# ── Authentication (Auth.js + Keycloak) ──
# Session signing secret — generate with: openssl rand -base64 32
AUTH_SECRET=dev-only-insecure-secret-change-me
# Public origin of this app
AUTH_URL=http://localhost:3000
# Trust X-Forwarded-* headers when running behind a proxy / container
AUTH_TRUST_HOST=true
# Keycloak OIDC client credentials + realm issuer.
# For local docker-compose, add `127.0.0.1 keycloak` to /etc/hosts so the
# browser can reach the issuer host. Override the issuer for external Keycloak.
AUTH_KEYCLOAK_ID=copilot-insights-dashboard
AUTH_KEYCLOAK_SECRET=dev-only-change-me
AUTH_KEYCLOAK_ISSUER=http://keycloak:8080/realms/copilot-insights
