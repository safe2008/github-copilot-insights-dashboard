{
  "realm": "copilot-insights",
  "enabled": true,
  "displayName": "Copilot Insights",
  "sslRequired": "external",
  "registrationAllowed": false,
  "loginWithEmailAllowed": true,
  "roles": {
    "realm": [
      {
        "name": "insights-admin",
        "description": "Full access: dashboards plus Settings and admin APIs"
      },
      {
        "name": "insights-viewer",
        "description": "Read-only access to dashboards"
      }
    ]
  },
  "clients": [
    {
      "clientId": "copilot-insights-dashboard",
      "name": "Copilot Insights Dashboard",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": false,
      "clientAuthenticatorType": "client-secret",
      "secret": "dev-only-change-me",
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": false,
      "redirectUris": ["http://localhost:3000/api/auth/callback/keycloak"],
      "webOrigins": ["http://localhost:3000"],
      "attributes": {
        "post.logout.redirect.uris": "http://localhost:3000"
      },
      "fullScopeAllowed": true
    }
  ],
  "users": [
    {
      "username": "admin",
      "enabled": true,
      "emailVerified": true,
      "email": "admin@example.com",
      "firstName": "Demo",
      "lastName": "Admin",
      "credentials": [
        {
          "type": "password",
          "value": "admin",
          "temporary": false
        }
      ],
      "realmRoles": ["insights-admin"]
    },
    {
      "username": "viewer",
      "enabled": true,
      "emailVerified": true,
      "email": "viewer@example.com",
      "firstName": "Demo",
      "lastName": "Viewer",
      "credentials": [
        {
          "type": "password",
          "value": "viewer",
          "temporary": false
        }
      ],
      "realmRoles": ["insights-viewer"]
    }
  ]
}
